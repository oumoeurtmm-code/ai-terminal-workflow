# ── n8n + OpenCode IT Automation — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values before running docker-compose.
# .env is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# n8n Basic Auth — protects the n8n web UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# n8n encryption key — backs up stored credentials; generate a random string
# Example: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-a-random-32-char-string

# Timezone — https://momentjs.com/timezone/ for valid values
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# n8n host settings (leave as-is for local development)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ── AI API Keys ───────────────────────────────────────────────────────────────

# Anthropic (Claude) — required for cloud-cost-report workflow
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini) — required for cloud-cost-report and access-request workflows
# Free tier available at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# ── Optional / Advanced ───────────────────────────────────────────────────────

# Perplexity — NOT required; workflows run with Claude + Gemini only
# Uncomment if you have a paid Perplexity API plan:
# PERPLEXITY_API_KEY=pplx-...

# AWS (for cloud-cost-report workflow — optional for local testing)
# The workflow includes sample cost data that works without live AWS credentials.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
